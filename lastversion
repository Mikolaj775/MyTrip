import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyBuBf-QqE6q0U2aH7qgRhzbwu2_dTs5K6w",
  authDomain: "mytrip-aa359.firebaseapp.com",
  projectId: "mytrip-aa359",
  storageBucket: "mytrip-aa359.firebasestorage.app",
  messagingSenderId: "79019124080",
  appId: "1:79019124080:web:3f77f514938a98aa4b5bb5",
  measurementId: "G-CXNERF2JVT"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const storage = getStorage(app);
const auth = getAuth(app);

// ══════════════════════════ STATE ══════════════════════════
let currentUser = null;
let places = [];
let soundFiles = {};
let nextId = 1;
let selectedCoords = null;
let selectedMP3 = null;
let selectedDistance = 50;
let currentMarker = null;
let allTrips = [];
let dragSrcIndex = null;

// ══════════════════════════ EXPOSE TO WINDOW ══════════════════════════
window.switchView = switchView;
window.openAuthModal = openAuthModal;
window.closeModal = closeModal;
window.handleLogout = handleLogout;
window.addPlace = addPlace;
window.exportZip = exportZip;
window.openSaveModal = openSaveModal;
window.saveTrip = saveTrip;
window.filterTrips = filterTrips;
window.setManualCoords = setManualCoords;
window.useMyLocation = useMyLocation;
window.openTripDetail = openTripDetail;

// ══════════════════════════ MAP ══════════════════════════
const map = L.map('map', {
  minZoom: 3, maxZoom: 18,
  maxBounds: [[-85,-180],[85,180]],
  maxBoundsViscosity: 1.0
}).setView([50.04, 18.63], 13);

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '©OpenStreetMap ©CARTO'
}).addTo(map);

map.on('click', e => {
  selectedCoords = [e.latlng.lat, e.latlng.lng];
  placeMarker(selectedCoords);
  updateCoordDisplay();
  checkAddBtn();
});

function placeMarker([lat, lng]) {
  if (currentMarker) map.removeLayer(currentMarker);
  const icon = L.divIcon({
    className: '',
    html: `<div style="
      width:14px; height:14px; border-radius:50%;
      background: #00e5ff;
      border: 2px solid #000;
      box-shadow: 0 0 12px #00e5ff, 0 0 4px #00e5ff;
    "></div>`,
    iconSize: [14,14],
    iconAnchor: [7,7]
  });
  currentMarker = L.marker([lat, lng], { icon }).addTo(map);
}

// ══════════════════════════ AUTH STATE ══════════════════════════
onAuthStateChanged(auth, user => {
  currentUser = user;
  const loginBtn = document.getElementById('login-btn');
  const userInfo = document.getElementById('user-info');
  const emailDisplay = document.getElementById('user-email-display');
  const avatar = document.getElementById('user-avatar');

  if (user) {
    loginBtn.style.display = 'none';
    userInfo.classList.add('visible');
    const email = user.email || '';
    emailDisplay.textContent = email;
    avatar.textContent = email[0]?.toUpperCase() || '?';
  } else {
    loginBtn.style.display = 'block';
    userInfo.classList.remove('visible');
  }
});

// ══════════════════════════ AUTH MODAL ══════════════════════════
function openAuthModal(mode) {
  const overlay = document.getElementById('modal-overlay');
  const content = document.getElementById('modal-content');
  overlay.classList.add('open');
  renderAuthForm(mode, content);
}

function renderAuthForm(mode, container) {
  const isLogin = mode === 'login';
  container.innerHTML = `
    <div class="modal-title">${isLogin ? 'Zaloguj się' : 'Utwórz konto'}</div>
    <div class="modal-sub">${isLogin ? 'Wróć do swoich wycieczek' : 'Zacznij tworzyć i udostępniać trasy'}</div>
    <div class="modal-field">
      <label>E-mail</label>
      <input id="auth-email" type="email" class="modal-input" placeholder="jan@przykład.pl" autocomplete="email">
    </div>
    <div class="modal-field">
      <label>Hasło</label>
      <input id="auth-password" type="password" class="modal-input" placeholder="••••••••" autocomplete="${isLogin ? 'current-password' : 'new-password'}">
    </div>
    <div class="modal-err" id="auth-err"></div>
    <div class="modal-footer">
      <button class="btn btn-primary" style="width:100%; padding:12px;" onclick="submitAuth('${mode}')">
        ${isLogin ? 'Zaloguj' : 'Zarejestruj się'}
      </button>
      <div class="modal-switch">
        ${isLogin
          ? `Nie masz konta? <a onclick="renderAuthForm('register', document.getElementById('modal-content'))">Zarejestruj się</a>`
          : `Masz już konto? <a onclick="renderAuthForm('login', document.getElementById('modal-content'))">Zaloguj się</a>`}
      </div>
    </div>
  `;
  setTimeout(() => document.getElementById('auth-email')?.focus(), 50);
}

window.renderAuthForm = renderAuthForm;

window.submitAuth = async (mode) => {
  const email = document.getElementById('auth-email').value.trim();
  const password = document.getElementById('auth-password').value;
  const errEl = document.getElementById('auth-err');
  errEl.textContent = '';

  if (!email || !password) { errEl.textContent = 'Wypełnij wszystkie pola.'; return; }

  try {
    if (mode === 'login') {
      await signInWithEmailAndPassword(auth, email, password);
    } else {
      await createUserWithEmailAndPassword(auth, email, password);
    }
    closeModal();
    showToast('Zalogowano pomyślnie!', 'success');
  } catch (e) {
    const msgs = {
      'auth/email-already-in-use': 'Ten e-mail jest już zarejestrowany.',
      'auth/invalid-email': 'Niepoprawny adres e-mail.',
      'auth/weak-password': 'Hasło musi mieć co najmniej 6 znaków.',
      'auth/user-not-found': 'Nie znaleziono konta.',
      'auth/wrong-password': 'Niepoprawne hasło.',
      'auth/invalid-credential': 'Niepoprawny e-mail lub hasło.',
    };
    errEl.textContent = msgs[e.code] || 'Błąd: ' + e.message;
  }
};

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

async function handleLogout() {
  await signOut(auth);
  showToast('Wylogowano.', 'info');
}

// ══════════════════════════ PLACE MANAGEMENT ══════════════════════════
function updateCoordDisplay() {
  const el = document.getElementById('coord-display');
  if (selectedCoords) {
    el.classList.add('has-coords');
    el.innerHTML = `<span style="color:var(--text-dim)">LAT</span> ${selectedCoords[0].toFixed(6)}&nbsp;&nbsp;<span style="color:var(--text-dim)">LNG</span> ${selectedCoords[1].toFixed(6)}`;
  } else {
    el.classList.remove('has-coords');
    el.textContent = 'Kliknij na mapie lub użyj lokalizacji';
  }
}

function checkAddBtn() {
  document.getElementById('addPlaceBtn').disabled = !(selectedCoords && selectedMP3);
}

function setManualCoords() {
  const lat = parseFloat(document.getElementById('latInput').value);
  const lng = parseFloat(document.getElementById('lngInput').value);
  if (isNaN(lat) || isNaN(lng)) { showToast('Podaj poprawne współrzędne.', 'error'); return; }
  selectedCoords = [lat, lng];
  placeMarker(selectedCoords);
  map.setView(selectedCoords, map.getZoom());
  updateCoordDisplay();
  checkAddBtn();
}

function useMyLocation() {
  if (!navigator.geolocation) { showToast('Geolokalizacja niedostępna.', 'error'); return; }
  navigator.geolocation.getCurrentPosition(pos => {
    selectedCoords = [pos.coords.latitude, pos.coords.longitude];
    document.getElementById('latInput').value = selectedCoords[0].toFixed(6);
    document.getElementById('lngInput').value = selectedCoords[1].toFixed(6);
    placeMarker(selectedCoords);
    map.setView(selectedCoords, 14);
    updateCoordDisplay();
    checkAddBtn();
  }, () => showToast('Nie można pobrać lokalizacji.', 'error'));
}

document.getElementById('mp3Input').addEventListener('change', e => {
  const file = e.target.files[0];
  const label = document.getElementById('mp3-label');
  const labelText = document.getElementById('mp3-label-text');
  if (file && file.type === 'audio/mpeg') {
    selectedMP3 = file;
    label.classList.add('has-file');
    labelText.textContent = '✓ ' + file.name;
  } else {
    selectedMP3 = null;
    label.classList.remove('has-file');
    labelText.textContent = 'Wybierz plik MP3';
  }
  checkAddBtn();
});

document.getElementById('distanceRange').addEventListener('input', e => {
  selectedDistance = parseInt(e.target.value);
  document.getElementById('distanceValue').textContent = selectedDistance + ' m';
});

function addPlace() {
  if (!selectedCoords || !selectedMP3) return;
  const name = document.getElementById('placeNameInput').value.trim() || selectedMP3.name.replace('.mp3','');
  const fileName = Date.now() + '_' + selectedMP3.name;

  const place = {
    id: nextId++,
    name,
    lat: selectedCoords[0],
    lng: selectedCoords[1],
    sound: fileName,
    radius: selectedDistance,
    side: 'center'
  };

  places.push(place);

  // Add map circle
  const circle = L.circle([place.lat, place.lng], {
    radius: place.radius,
    color: '#00e5ff', fillColor: '#00e5ff', fillOpacity: 0.08,
    weight: 1
  }).addTo(map);

  const reader = new FileReader();
  reader.onload = () => { soundFiles[fileName] = reader.result; };
  reader.readAsArrayBuffer(selectedMP3);

  // Reset
  selectedMP3 = null;
  document.getElementById('placeNameInput').value = '';
  document.getElementById('mp3Input').value = '';
  document.getElementById('mp3-label').classList.remove('has-file');
  document.getElementById('mp3-label-text').textContent = 'Wybierz plik MP3';
  checkAddBtn();
  refreshPlaceList(true);
  showToast('Miejsce dodane: ' + name, 'success');
}

// ══════════════════════════ DRAG & DROP ══════════════════════════
function refreshPlaceList(animateLast = false) {
  const list = document.getElementById('placeList');
  list.innerHTML = '';
  document.getElementById('place-count').textContent = places.length;

  places.forEach((p, i) => {
    const entry = buildPlaceEntry(p, i);
    if (animateLast && i === places.length - 1) entry.classList.add('new-entry');
    list.appendChild(entry);
  });
}

function buildPlaceEntry(p, index) {
  const div = document.createElement('div');
  div.className = `place-entry side-${p.side}`;
  div.draggable = true;
  div.dataset.index = index;

  div.innerHTML = `
    <div class="place-inner">
      <div class="place-side-indicator"></div>
      <div class="place-body">
        <div class="place-name">${p.name}</div>
        <div class="place-meta">${p.lat.toFixed(4)}, ${p.lng.toFixed(4)} · ${p.radius}m</div>
        <div class="place-side-badge">${p.side === 'left' ? '◀ LEWO' : p.side === 'right' ? 'PRAWO ▶' : '● ŚRODEK'}</div>
      </div>
      <div class="place-actions">
        <button class="side-btn ${p.side==='left'?'active-left':''}" title="Lewo" onclick="setSide(${index},'left')">◀</button>
        <button class="side-btn ${p.side==='center'?'active-center':''}" title="Środek" onclick="setSide(${index},'center')">●</button>
        <button class="side-btn ${p.side==='right'?'active-right':''}" title="Prawo" onclick="setSide(${index},'right')">▶</button>
        <button class="side-btn delete-btn" title="Usuń" onclick="removePlace(${index})">✕</button>
      </div>
    </div>
  `;

  // DRAG EVENTS
  div.addEventListener('dragstart', e => {
    dragSrcIndex = index;
    div.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
  });

  div.addEventListener('dragend', () => {
    div.classList.remove('dragging');
    document.querySelectorAll('.place-entry').forEach(el => {
      el.classList.remove('drag-over-before', 'drag-over-after');
    });
  });

  div.addEventListener('dragover', e => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    document.querySelectorAll('.place-entry').forEach(el => {
      el.classList.remove('drag-over-before', 'drag-over-after');
    });
    const rect = div.getBoundingClientRect();
    const mid = rect.top + rect.height / 2;
    if (e.clientY < mid) {
      div.classList.add('drag-over-before');
    } else {
      div.classList.add('drag-over-after');
    }
  });

  div.addEventListener('dragleave', () => {
    div.classList.remove('drag-over-before', 'drag-over-after');
  });

  div.addEventListener('drop', e => {
    e.preventDefault();
    div.classList.remove('drag-over-before', 'drag-over-after');
    if (dragSrcIndex === null || dragSrcIndex === index) return;

    const rect = div.getBoundingClientRect();
    const mid = rect.top + rect.height / 2;
    const insertBefore = e.clientY < mid;

    const [dragged] = places.splice(dragSrcIndex, 1);
    const newIndex = insertBefore ? index : index + (dragSrcIndex < index ? 0 : 1);
    places.splice(Math.max(0, dragSrcIndex < index ? newIndex - 1 : newIndex), 0, dragged);

    dragSrcIndex = null;
    refreshPlaceList();
  });

  return div;
}

window.setSide = (index, side) => {
  places[index].side = side;
  const entry = document.querySelector(`[data-index="${index}"]`);
  if (entry) {
    // animate side change
    entry.style.transform = 'scale(0.97)';
    setTimeout(() => {
      entry.style.transform = '';
      refreshPlaceList();
    }, 150);
  }
};

window.removePlace = (index) => {
  const entry = document.querySelector(`[data-index="${index}"]`);
  if (entry) {
    entry.style.transform = 'translateX(-20px)';
    entry.style.opacity = '0';
    setTimeout(() => {
      places.splice(index, 1);
      refreshPlaceList();
    }, 200);
  }
};

// ══════════════════════════ VIEW SWITCHING ══════════════════════════
function switchView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  const navBtns = document.querySelectorAll('.nav-btn');
  navBtns[name === 'creator' ? 0 : 1].classList.add('active');
  if (name === 'trips') loadTrips();
  if (name === 'creator') setTimeout(() => map.invalidateSize(), 100);
}

// ══════════════════════════ TRIPS ══════════════════════════
let currentFilter = 'all';

async function loadTrips() {
  const grid = document.getElementById('trips-grid');
  grid.innerHTML = `<div class="loading-spinner"><div class="spinner-ring"></div><span>Ładowanie wycieczek...</span></div>`;

  try {
    const q = query(collection(db, 'trips'), orderBy('createdAt', 'desc'));
    const snap = await getDocs(q);
    allTrips = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderTrips(allTrips);
  } catch(e) {
    grid.innerHTML = `<div class="loading-spinner" style="color:var(--accent2)">Błąd ładowania. Sprawdź połączenie.</div>`;
  }
}

function filterTrips(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  let filtered = allTrips;
  if (type === 'mine' && currentUser) {
    filtered = allTrips.filter(t => t.authorId === currentUser.uid);
  } else if (type === 'mine' && !currentUser) {
    showToast('Zaloguj się, żeby zobaczyć swoje wycieczki.', 'info');
    return;
  }
  renderTrips(filtered);
}

function renderTrips(trips) {
  const grid = document.getElementById('trips-grid');
  grid.innerHTML = '';

  if (trips.length === 0) {
    grid.innerHTML = `<div class="loading-spinner">Brak wycieczek.</div>`;
    return;
  }

  trips.forEach((trip, i) => {
    const card = buildTripCard(trip, i);
    grid.appendChild(card);
  });
}

function buildTripCard(trip, i) {
  const div = document.createElement('div');
  div.className = 'trip-card';
  div.style.animationDelay = (i * 0.05) + 's';

  const places = trip.places || [];
  const count = places.length;

  // Mini map visualization
  const dots = places.slice(0, 8).map(p => {
    const x = ((p.lng + 180) / 360 * 100).toFixed(1);
    const y = ((90 - p.lat) / 180 * 100).toFixed(1);
    return `<div class="trip-dot" style="left:${x}%;top:${y}%"></div>`;
  }).join('');

  const author = trip.authorEmail ? trip.authorEmail.split('@')[0] : 'anonim';
  const dateStr = trip.createdAt?.toDate ? trip.createdAt.toDate().toLocaleDateString('pl-PL') : '—';

  div.innerHTML = `
    <div class="trip-card-map">${dots}</div>
    <div class="trip-card-body">
      <div class="trip-card-title">${trip.title}</div>
      <div class="trip-card-meta">
        <span>📍 ${count} miejsc</span>
        <span>📅 ${dateStr}</span>
      </div>
      <div class="trip-card-author">@${author}</div>
    </div>
    <div class="trip-card-footer">
      <span style="font-size:12px;color:var(--text-dim)">${count > 0 ? places[0].name : ''}</span>
      <button class="btn btn-primary" onclick="openTripDetail('${trip.id}')">Szczegóły</button>
    </div>
  `;
  return div;
}

function openTripDetail(tripId) {
  const trip = allTrips.find(t => t.id === tripId);
  if (!trip) return;

  const overlay = document.getElementById('trip-detail-overlay');
  const content = document.getElementById('trip-detail-content');
  overlay.classList.add('open');

  const dateStr = trip.createdAt?.toDate ? trip.createdAt.toDate().toLocaleDateString('pl-PL') : '—';
  const author = trip.authorEmail ? trip.authorEmail.split('@')[0] : 'anonim';

  const placeRows = (trip.places || []).map((p, i) => `
    <div class="detail-place-row side-${p.side || 'center'}">
      <div class="detail-place-num">#${i+1}</div>
      <div class="detail-place-info">
        <div class="detail-place-name">${p.name}</div>
        <div class="detail-place-coords">${(p.lat||0).toFixed(5)}, ${(p.lng||0).toFixed(5)} · ${p.radius||'?'}m</div>
      </div>
      ${p.soundUrl ? `<a href="${p.soundUrl}" target="_blank" class="detail-play-btn">▶ Odtwórz</a>` : ''}
    </div>
  `).join('');

  content.innerHTML = `
    <div class="trip-detail-title">${trip.title}</div>
    <div class="trip-detail-author">@${author} · ${dateStr}</div>
    ${placeRows || '<p style="color:var(--text-dim);font-size:14px">Brak miejsc w tej wycieczce.</p>'}
  `;
}

// ══════════════════════════ SAVE TRIP ══════════════════════════
function openSaveModal() {
  if (!currentUser) {
    openAuthModal('login');
    showToast('Zaloguj się, żeby zapisać wycieczkę.', 'info');
    return;
  }
  if (places.length === 0) { showToast('Dodaj przynajmniej jedno miejsce.', 'error'); return; }
  document.getElementById('save-modal-overlay').classList.add('open');
}

async function saveTrip() {
  const title = document.getElementById('tripTitleInput').value.trim();
  const errEl = document.getElementById('save-err');
  if (!title) { errEl.textContent = 'Podaj nazwę wycieczki.'; return; }
  errEl.textContent = '';

  const btn = document.querySelector('#save-modal-overlay .btn-primary');
  btn.textContent = 'Zapisywanie...';
  btn.disabled = true;

  try {
    const uploadedPlaces = [];
    for (const place of places) {
      const blob = soundFiles[place.sound];
      let soundUrl = null;
      if (blob) {
        const r = ref(storage, `trips/${Date.now()}_${place.sound}`);
        await uploadBytes(r, blob);
        soundUrl = await getDownloadURL(r);
      }
      uploadedPlaces.push({
        id: place.id,
        name: place.name,
        lat: place.lat,
        lng: place.lng,
        radius: place.radius,
        side: place.side,
        soundUrl
      });
    }

    await addDoc(collection(db, 'trips'), {
      title,
      places: uploadedPlaces,
      authorId: currentUser.uid,
      authorEmail: currentUser.email,
      createdAt: serverTimestamp()
    });

    document.getElementById('save-modal-overlay').classList.remove('open');
    document.getElementById('tripTitleInput').value = '';
    showToast('Wycieczka zapisana! 🎉', 'success');
  } catch(e) {
    errEl.textContent = 'Błąd zapisu: ' + e.message;
  } finally {
    btn.textContent = 'Zapisz w chmurze';
    btn.disabled = false;
  }
}

// ══════════════════════════ EXPORT ZIP ══════════════════════════
function exportZip() {
  if (places.length === 0) { showToast('Brak miejsc do eksportu.', 'error'); return; }
  const zip = new JSZip();
  const placesData = places.map((p, i) => ({
    id: i + 1, name: p.name, lat: p.lat, lng: p.lng,
    sound: p.sound, radius: p.radius, side: p.side
  }));
  zip.file('places.json', JSON.stringify(placesData, null, 2));
  const sounds = zip.folder('sounds');
  for (const [name, data] of Object.entries(soundFiles)) {
    sounds.file(name, data);
  }
  zip.generateAsync({ type: 'blob' }).then(blob => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'soundmap_trip.zip';
    a.click();
    showToast('ZIP pobrany!', 'success');
  });
}

// ══════════════════════════ TOAST ══════════════════════════
function showToast(msg, type = 'info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'show ' + type;
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.classList.remove('show'), 3000);
}

window.showToast = showToast;

// ══════════════════════════ INIT ══════════════════════════
updateCoordDisplay();
refreshPlaceList();

// Try auto-locate
if (navigator.geolocation) {
  navigator.geolocation.getCurrentPosition(pos => {
    const lat = pos.coords.latitude, lng = pos.coords.longitude;
    selectedCoords = [lat, lng];
    document.getElementById('latInput').value = lat.toFixed(6);
    document.getElementById('lngInput').value = lng.toFixed(6);
    placeMarker(selectedCoords);
    map.setView(selectedCoords, 14);
    updateCoordDisplay();
    checkAddBtn();
  });
}

// Close modals on overlay click
document.getElementById('modal-overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeModal();
});
document.getElementById('trip-detail-overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) document.getElementById('trip-detail-overlay').classList.remove('open');
});
document.getElementById('save-modal-overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) document.getElementById('save-modal-overlay').classList.remove('open');
});
</script>
