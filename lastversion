<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SoundMap – Twórca Wycieczek</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.7.1/jszip.min.js"></script>
  <style>
    :root {
      --bg: #0a0a0f;
      --surface: #13131a;
      --surface2: #1c1c28;
      --border: #2a2a3d;
      --accent: #00e5ff;
      --accent2: #ff3d71;
      --accent3: #a855f7;
      --text: #e8e8f0;
      --text-dim: #6b6b8a;
      --success: #00e096;
      --left-color: #3b82f6;
      --right-color: #f97316;
      --center-color: #a855f7;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ═══════════════════════════════ HEADER ═══════════════════════════════ */
    #header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      height: 56px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      z-index: 1000;
    }

    #header .logo {
      font-family: 'Space Mono', monospace;
      font-size: 18px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.5px;
    }

    #header .logo span { color: var(--accent2); }

    #nav {
      display: flex;
      gap: 4px;
    }

    .nav-btn {
      padding: 6px 16px;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 600;
      border: 1px solid transparent;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      background: transparent;
      color: var(--text-dim);
      letter-spacing: 0.5px;
    }

    .nav-btn:hover { color: var(--text); border-color: var(--border); background: var(--surface2); }
    .nav-btn.active { color: var(--accent); border-color: var(--accent); background: rgba(0,229,255,0.08); }

    #auth-area {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    #user-info {
      font-size: 13px;
      color: var(--text-dim);
      display: none;
    }

    #user-info.visible { display: flex; align-items: center; gap: 8px; }

    #user-avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent3), var(--accent));
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: #fff;
    }

    .btn {
      padding: 7px 16px;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 600;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 0.3px;
    }

    .btn-primary { background: var(--accent); color: #000; }
    .btn-primary:hover { background: #00c4db; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,229,255,0.3); }

    .btn-ghost { background: transparent; color: var(--text-dim); border: 1px solid var(--border); }
    .btn-ghost:hover { color: var(--text); border-color: var(--text-dim); }

    .btn-danger { background: var(--accent2); color: #fff; }
    .btn-danger:hover { background: #e0305f; }

    .btn-success { background: var(--success); color: #000; }
    .btn-success:hover { filter: brightness(0.9); }

    /* ═══════════════════════════════ VIEWS ═══════════════════════════════ */
    .view {
      flex: 1;
      overflow: hidden;
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .view.active { display: flex; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ═══════════════════════════════ CREATOR VIEW ═══════════════════════════════ */
    #view-creator {
      flex-direction: row;
    }

    /* LEFT PANEL */
    #left-panel {
      width: 340px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border-right: 1px solid var(--border);
      overflow: hidden;
    }

    #panel-top {
      padding: 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .panel-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--text-dim);
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .coord-row {
      display: flex;
      gap: 8px;
    }

    .input-field {
      flex: 1;
      padding: 8px 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      outline: none;
      transition: border-color 0.2s;
    }

    .input-field:focus { border-color: var(--accent); }
    .input-field::placeholder { color: var(--text-dim); }

    .input-field-text {
      width: 100%;
      padding: 8px 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      outline: none;
      transition: border-color 0.2s;
    }

    .input-field-text:focus { border-color: var(--accent); }
    .input-field-text::placeholder { color: var(--text-dim); }

    .btn-row {
      display: flex;
      gap: 8px;
    }

    .btn-row .btn { flex: 1; font-size: 12px; padding: 7px 8px; }

    .file-upload-label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      background: var(--surface2);
      border: 1px dashed var(--border);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 13px;
      color: var(--text-dim);
    }

    .file-upload-label:hover { border-color: var(--accent); color: var(--accent); }
    .file-upload-label.has-file { border-color: var(--success); color: var(--success); }
    .file-upload-label svg { flex-shrink: 0; }

    input[type="file"] { display: none; }

    .range-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .range-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    input[type="range"] {
      flex: 1;
      accent-color: var(--accent);
      height: 4px;
    }

    .range-val {
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: var(--accent);
      min-width: 45px;
      text-align: right;
    }

    #coord-display {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--text-dim);
      background: var(--surface2);
      padding: 8px 10px;
      border-radius: 6px;
      border: 1px solid var(--border);
      line-height: 1.6;
    }

    #coord-display.has-coords { color: var(--accent); border-color: rgba(0,229,255,0.3); }

    .btn-add-place {
      width: 100%;
      padding: 12px;
      font-size: 14px;
      font-weight: 800;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), var(--accent3));
      color: #000;
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 1px;
    }

    .btn-add-place:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,229,255,0.35); }
    .btn-add-place:active { transform: translateY(0); }
    .btn-add-place:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

    /* PLACE LIST */
    #place-list-header {
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    #place-count {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      background: var(--accent);
      color: #000;
      padding: 2px 8px;
      border-radius: 20px;
      font-weight: 700;
    }

    #placeList {
      flex: 1;
      overflow-y: auto;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    #placeList::-webkit-scrollbar { width: 4px; }
    #placeList::-webkit-scrollbar-track { background: transparent; }
    #placeList::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* ═══════════════════════════════ PLACE ENTRIES ═══════════════════════════════ */
    .place-entry {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
      cursor: grab;
      user-select: none;
    }

    .place-entry:active { cursor: grabbing; }

    .place-entry.dragging {
      opacity: 0.4;
      transform: scale(0.96);
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(0,229,255,0.2);
    }

    .place-entry.drag-over {
      transform: translateY(4px);
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(0,229,255,0.2);
    }

    .place-entry.drag-over-before {
      border-top-color: var(--accent);
      box-shadow: 0 -3px 0 0 var(--accent);
    }

    .place-entry.drag-over-after {
      border-bottom-color: var(--accent);
      box-shadow: 0 3px 0 0 var(--accent);
    }

    /* animate in */
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-12px); }
      to { opacity: 1; transform: translateX(0); }
    }

    .place-entry.new-entry { animation: slideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }

    .place-inner {
      display: flex;
      align-items: stretch;
      height: 52px;
    }

    .place-side-indicator {
      width: 4px;
      flex-shrink: 0;
      transition: background 0.3s;
    }

    .side-center .place-side-indicator { background: var(--center-color); }
    .side-left .place-side-indicator { background: var(--left-color); }
    .side-right .place-side-indicator { background: var(--right-color); }

    .place-body {
      flex: 1;
      padding: 8px 10px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2px;
      min-width: 0;
    }

    .place-name {
      font-size: 13px;
      font-weight: 700;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .place-meta {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      color: var(--text-dim);
    }

    .place-side-badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 1px 6px;
      border-radius: 3px;
      margin-top: 2px;
      display: inline-block;
      width: fit-content;
    }

    .side-center .place-side-badge { background: rgba(168,85,247,0.2); color: var(--center-color); }
    .side-left .place-side-badge { background: rgba(59,130,246,0.2); color: var(--left-color); }
    .side-right .place-side-badge { background: rgba(249,115,22,0.2); color: var(--right-color); }

    /* SIDE SWITCHER on right side of entry */
    .place-actions {
      display: flex;
      flex-direction: column;
      border-left: 1px solid var(--border);
    }

    .side-btn {
      flex: 1;
      width: 32px;
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--text-dim);
      font-size: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
    }

    .side-btn:hover { background: var(--surface); color: var(--text); }

    .side-btn.active-left { color: var(--left-color); background: rgba(59,130,246,0.1); }
    .side-btn.active-center { color: var(--center-color); background: rgba(168,85,247,0.1); }
    .side-btn.active-right { color: var(--right-color); background: rgba(249,115,22,0.1); }

    .side-btn.delete-btn:hover { color: var(--accent2); background: rgba(255,61,113,0.1); }

    /* DROP INDICATOR LINE */
    .drop-indicator {
      height: 3px;
      background: var(--accent);
      border-radius: 2px;
      margin: 2px 0;
      opacity: 0;
      transition: opacity 0.15s;
    }

    .drop-indicator.visible { opacity: 1; }

    /* ═══════════════════════════════ MAP ═══════════════════════════════ */
    #map-container {
      flex: 1;
      position: relative;
    }

    #map { width: 100%; height: 100%; }

    /* ═══════════════════════════════ EXPORT BAR ═══════════════════════════════ */
    #export-bar {
      position: absolute;
      bottom: 24px;
      right: 24px;
      display: flex;
      gap: 8px;
      z-index: 999;
    }

    #export-bar .btn {
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    }

    /* ═══════════════════════════════ TRIPS VIEW ═══════════════════════════════ */
    #view-trips {
      flex-direction: column;
      overflow: hidden;
    }

    #trips-header {
      padding: 24px 32px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    #trips-header h2 {
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    #trips-header p { color: var(--text-dim); font-size: 14px; margin-top: 4px; }

    #trips-filter {
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .filter-btn {
      padding: 5px 14px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      color: var(--text-dim);
      font-family: 'Syne', sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn:hover, .filter-btn.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0,229,255,0.08);
    }

    #trips-grid {
      flex: 1;
      overflow-y: auto;
      padding: 24px 32px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
      align-content: start;
    }

    #trips-grid::-webkit-scrollbar { width: 4px; }
    #trips-grid::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .trip-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: all 0.25s;
      cursor: pointer;
      animation: fadeIn 0.4s ease both;
    }

    .trip-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0,229,255,0.12);
    }

    .trip-card-map {
      height: 140px;
      background: var(--surface2);
      position: relative;
      overflow: hidden;
    }

    /* mini map dots */
    .trip-dot {
      position: absolute;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--accent);
      transform: translate(-50%, -50%);
      box-shadow: 0 0 6px var(--accent);
    }

    .trip-card-body {
      padding: 14px;
    }

    .trip-card-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .trip-card-meta {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--text-dim);
      display: flex;
      gap: 12px;
    }

    .trip-card-author {
      font-size: 12px;
      color: var(--accent3);
      margin-top: 6px;
      font-weight: 600;
    }

    .trip-card-footer {
      padding: 10px 14px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .trip-card-footer .btn { font-size: 12px; padding: 5px 12px; }

    /* loading / empty */
    .loading-spinner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 60px;
      color: var(--text-dim);
      font-size: 14px;
      grid-column: 1/-1;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .spinner-ring {
      width: 32px; height: 32px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    /* ═══════════════════════════════ AUTH MODAL ═══════════════════════════════ */
    #modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(6px);
      z-index: 9999;
      display: none;
      align-items: center;
      justify-content: center;
      animation: fadeIn 0.2s ease;
    }

    #modal-overlay.open { display: flex; }

    .modal-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      width: 380px;
      max-width: 90vw;
      animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.9) translateY(20px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-title {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .modal-sub {
      font-size: 13px;
      color: var(--text-dim);
      margin-bottom: 24px;
    }

    .modal-field {
      margin-bottom: 14px;
    }

    .modal-field label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      color: var(--text-dim);
      margin-bottom: 6px;
      text-transform: uppercase;
    }

    .modal-input {
      width: 100%;
      padding: 10px 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }

    .modal-input:focus { border-color: var(--accent); }

    .modal-err {
      color: var(--accent2);
      font-size: 12px;
      min-height: 16px;
      margin-bottom: 10px;
    }

    .modal-footer {
      margin-top: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .modal-switch {
      text-align: center;
      font-size: 13px;
      color: var(--text-dim);
    }

    .modal-switch a {
      color: var(--accent);
      cursor: pointer;
      text-decoration: none;
      font-weight: 600;
    }

    .modal-close {
      position: absolute;
      top: 16px; right: 16px;
      background: transparent;
      border: none;
      color: var(--text-dim);
      font-size: 20px;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
    }

    .modal-close:hover { color: var(--text); background: var(--surface2); }

    /* ═══════════════════════════════ TRIP DETAIL MODAL ═══════════════════════════════ */
    #trip-detail-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(6px);
      z-index: 9998;
      display: none;
      align-items: center;
      justify-content: center;
    }

    #trip-detail-overlay.open { display: flex; }

    .trip-detail-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      width: 500px;
      max-width: 90vw;
      max-height: 80vh;
      overflow-y: auto;
      position: relative;
      animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .trip-detail-box::-webkit-scrollbar { width: 4px; }
    .trip-detail-box::-webkit-scrollbar-thumb { background: var(--border); }

    .trip-detail-title {
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .trip-detail-author {
      font-size: 13px;
      color: var(--accent3);
      margin-bottom: 16px;
    }

    .detail-place-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px;
      background: var(--surface2);
      border-radius: 8px;
      margin-bottom: 8px;
      border-left: 3px solid var(--border);
    }

    .detail-place-row.side-left { border-left-color: var(--left-color); }
    .detail-place-row.side-right { border-left-color: var(--right-color); }
    .detail-place-row.side-center { border-left-color: var(--center-color); }

    .detail-place-num {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--text-dim);
      min-width: 20px;
    }

    .detail-place-info { flex: 1; }
    .detail-place-name { font-size: 14px; font-weight: 700; }
    .detail-place-coords { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--text-dim); }

    .detail-play-btn {
      padding: 5px 10px;
      background: rgba(0,229,255,0.1);
      border: 1px solid rgba(0,229,255,0.3);
      border-radius: 6px;
      color: var(--accent);
      font-size: 12px;
      cursor: pointer;
      transition: all 0.15s;
      text-decoration: none;
    }

    .detail-play-btn:hover { background: rgba(0,229,255,0.2); }

